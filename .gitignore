.venv/
__pycache__/
*.pyc
.pytest_cache/
*.log

# --- Secrets ------------------------------------------------------------------
# This repo is public. Everything that could hold a credential is ignored by
# pattern rather than by name, because the file that leaks a key is always the one
# nobody thought to list.
#
# .streamlit/secrets.toml is the dangerous one: it is exactly where Streamlit's
# own docs tell you to put an API key for local development, it sits inside a
# directory we DO commit (config.toml lives there), and it is not called ".env".
.env
.env.*
!.env.example
secrets.toml
.streamlit/secrets.toml
*.key
*.pem
*.p12
credentials.json

# --- Backend cache -----------------------------------------------------------
# The cache holds two very different kinds of file, and only one kind belongs in
# git:
#
#   * RAW ARCHIVE DOWNLOADS (ignored) — re-fetchable from NASA OSDR. These are
#     large: the Inspiration4 counts .xlsx alone is 123 MB, which is over
#     GitHub's 100 MB hard limit and would make the push fail outright.
#
#   * DERIVED RESULTS (committed) — DESeq2 tables, forecast fits, ortholog
#     tables. ~4.7 MB total, and expensive to recompute: a cold /api/abtest is a
#     ~16s DESeq2 run. Committing them means a judge's first request on every
#     page is served warm instead of paying that on a sleeping free-tier dyno.
#
# So: ignore the cache's contents, then carve out the derived results.
backend/data/cache/*
!backend/data/cache/de/
!backend/data/cache/forecast/
!backend/data/cache/integrate/

# Retrieved PubMed records (committed). Small, and they are a courtesy to NCBI as
# much as to us: a demo that re-queries E-utilities on every click is a demo that
# gets throttled mid-sentence. Committing them means the literature a viewer sees
# is served from disk, and a PubMed outage cannot take the feature down live.
!backend/data/cache/literature/

# The I4 complete-blood-count CSV (9 KB). GET /api/forecast (the analyte
# allowlist that populates the dropdown) is not itself cached and parses this
# file, so without it that first request makes a live call to OSDR.
!backend/data/cache/OSD-569__file__36bc5a6eb813.csv

backend/results/

# Frontend
node_modules/
frontend/dist/
frontend/.vite/
.DS_Store
