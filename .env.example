# Copy to `.env` (which is git-ignored) and paste your key.
#
# Only the AI research assistant needs this. Both analysis workflows run without
# it; the assistant shows a "not configured" notice instead of failing.
#
# The key is read ONLY from this file locally, or from Streamlit secrets when
# deployed. It is never read from the ambient shell environment.
ANTHROPIC_API_KEY=sk-ant-...
